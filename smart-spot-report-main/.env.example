# Copy this file to ".env" and fill in the values.
# These are auto-provided by Lovable Cloud — paste the real values from the
# .env file you exported with the project.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# OPTIONAL — Manual backend (see /backend folder).
# Leave EMPTY to keep using Lovable Cloud directly (default).
# Set to http://localhost:5000/api when running the local Express server in VS Code.
VITE_API_BASE_URL=
