# Backend environment variables
# Copy this file to ".env" inside the /backend folder and fill in the values
# from the Lovable Cloud project (same values as the root .env file).

# Server
PORT=5000

# Supabase / Lovable Cloud
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Service role key — ONLY for the manual backend (never put this in the frontend!)
# Get it from Lovable Cloud → Backend → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Lovable AI Gateway (used by /api/detect endpoint)
LOVABLE_API_KEY=your-lovable-ai-key
